CREATE OR REPLACE FUNCTION public.jwt_is_admin()
RETURNS boolean
LANGUAGE sql
STABLE
SECURITY INVOKER
SET search_path = public
AS $$
  SELECT COALESCE(
    nullif(trim(auth.jwt() -> 'app_metadata' ->> 'role'), '') = 'admin'
    OR nullif(trim(auth.jwt() -> 'user_metadata' ->> 'role'), '') = 'admin',
    false
  );
$$;

