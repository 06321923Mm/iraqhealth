# انسخ هذا الملف إلى assets/env/flutter.env أو عدّل flutter.env مباشرة.
# أو مرّر القيم عند البناء: flutter run --dart-define=SUPABASE_URL=...

# من Supabase → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# من Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client IDs
# أنشئ عميلاً من نوع "Web application" واستخدم "Client ID" هنا (مطلوب لتسجيل الدخول عبر Google على الهاتف).
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# اختياري: إن أردت مخطط إعادة توجيه مخصصاً (يجب تطابقه مع لوحة Supabase وAndroid/iOS)
# OAUTH_REDIRECT_URL=net.iraqhealth.app://login-callback/
