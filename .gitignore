.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# VS Code — exclude launch.json (contains ADMIN_PASSWORD dart-define)
.vscode/launch.json
.vscode/settings.json

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
# iOS Google Maps SDK key for Info.plist ($(MAPS_API_KEY)); copy from MapsApiKey.xcconfig.example
ios/Flutter/MapsApiKey.xcconfig
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android signing secrets — NEVER commit these
*.jks
*.keystore
android/key.properties
android/local.properties

# Firebase config — contains API keys, keep private
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# Node tooling (geocode script)
tools/geocode-doctors/node_modules/

# Cursor IDE
.cursor/

# Supabase temp files
supabase/.temp/
